{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Genre 2",
	"slug": "text-genre-2",
	"blockTypes": [
		"core/heading",
		"core/paragraph",
		"core/accordion-heading",
		"core/query-title"
	],
	"styles": {
		"typography": {
			"fontSize": "var(--wp--preset--font-size--minuscule)",
			"fontWeight": "normal",
			"fontStyle": "normal",
			"lineHeight": "var(--wp--custom--global--line-height--petite)"
		},
		"css": "& { width: fit-content; writing-mode: vertical-rl; transform: rotate(180deg); }"
	}
}
